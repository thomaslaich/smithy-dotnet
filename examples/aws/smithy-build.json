{
  "version": "1.0",
  "sources": ["model"],
  "maven": {
    "repositories": [
      { "url": "file://~/.m2/repository" },
      { "url": "https://repo.maven.apache.org/maven2/" }
    ],
    "dependencies": [
      "software.amazon.smithy:smithy-aws-traits:1.68.0",
      "io.github.thomaslaich.smithy:smithy-csharp-codegen:0.1.0-SNAPSHOT"
    ]
  },
  "projections": {
    "rpcv2cbor": {
      "transforms": [
        { "name": "includeServices", "args": { "services": ["example.hello#HelloService"] } }
      ],
      "plugins": {
        "csharp-codegen": {
          "service": "example.hello#HelloService",
          "baseNamespace": ""
        }
      }
    },
    "restxml": {
      "transforms": [
        { "name": "includeServices", "args": { "services": ["example.hello#HelloXmlService"] } }
      ],
      "plugins": {
        "csharp-codegen": {
          "service": "example.hello#HelloXmlService",
          "baseNamespace": ""
        }
      }
    }
  }
}
