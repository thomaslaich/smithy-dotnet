<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <NoWarn>$(NoWarn);NU5100</NoWarn>
    <TargetsForTfmSpecificContentInPackage>
      $(TargetsForTfmSpecificContentInPackage);AddSmithyTaskFilesToPackage
    </TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Build.Framework" PrivateAssets="all" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" PrivateAssets="all" />
    <ProjectReference
      Include="../SmithyNet.CodeGeneration/SmithyNet.CodeGeneration.csproj"
      PrivateAssets="all"
    />
  </ItemGroup>

  <ItemGroup>
    <None
      Include="Targets/SmithyNet.MSBuild.targets"
      Pack="true"
      PackagePath="build/SmithyNet.MSBuild.targets"
    />
    <None
      Include="Targets/SmithyNet.MSBuild.targets"
      Pack="true"
      PackagePath="buildTransitive/SmithyNet.MSBuild.targets"
    />
  </ItemGroup>

  <Target Name="AddSmithyTaskFilesToPackage">
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(TargetDir)SmithyNet.MSBuild.dll" PackagePath="tasks/" />
      <TfmSpecificPackageFile
        Include="$(TargetDir)SmithyNet.CodeGeneration.dll"
        PackagePath="tasks/"
      />
      <TfmSpecificPackageFile Include="$(TargetDir)SmithyNet.Core.dll" PackagePath="tasks/" />
    </ItemGroup>
  </Target>
</Project>
